# Python Virtual Environments
venv/
.venv/
env/

# Python Cache (Temporary files generated by Python)
__pycache__/
*.py[cod]
*$py.class

# macOS System Files (Prevents hidden desktop files from uploading)
.DS_Store
.AppleDouble
.LSOverride

# Streamlit Configuration / Secrets
.streamlit/secrets.toml

# Jupyter Notebook Checkpoints (If you end up using notebooks later)
.ipynb_checkpoints/